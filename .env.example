# اختياري: توكن تصدير Finviz Elite لتطبيق الفلاتر بصيغتها الأصلية حرفياً
# تجده في رابط التصدير داخل حسابك: https://elite.finviz.com/export.ashx?...&auth=TOKEN
FINVIZ_AUTH_TOKEN=

# ===== الملخص اليومي على واتساب (/api/digest) =====
# سر الجدولة — أي نص عشوائي طويل. Vercel Cron يرسله تلقائياً عند ضبطه.
CRON_SECRET=

# الخيار 1 (الأسهل — CallMeBot المجاني للاستخدام الشخصي):
# أرسل من واتسابك «I allow callmebot to send me messages» إلى رقم البوت
# المذكور في callmebot.com/blog/free-api-whatsapp-messages فيصلك apikey
CALLMEBOT_PHONE=
CALLMEBOT_APIKEY=

# الخيار 2 (الرسمي — WhatsApp Cloud API من Meta):
# تنبيه: النص الحر يصل فقط خلال 24 ساعة من آخر رسالة من المستلم
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_TO=

# الخيار 3 (بوابة QR المحلية — الربط من صفحة «تنبيهاتي» في المنصة):
# شغّل البوابة (cd gateway && npm start) واضبط رابطها هنا. من داخل دوكر
# استخدم http://host.docker.internal:8899 — ومن dev مباشرة http://localhost:8899
GATEWAY_URL=

# الرابط العام الذي يظهر في روابط رسائل واتساب (اختياري — الافتراضي رابط
# النشر المباشر كي تُفتح الروابط من الجوال)
PUBLIC_SITE_URL=

# ===== إرسال البريد (اختياري — استرجاع كلمة المرور وتوثيق البريد) =====
# مفتاح Resend (resend.com — الخطة المجانية تكفي البداية). بدونه يسقط
# استرجاع كلمة المرور لقناة واتساب المرتبطة، ويتعطل توثيق البريد بسلاسة.
RESEND_API_KEY=
# عنوان المرسل الموثق في Resend، مثال: Sahm <no-reply@yourdomain.com>
MAIL_FROM=
