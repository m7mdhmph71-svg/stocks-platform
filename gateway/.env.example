# رابط منصتك على Vercel
SITE_URL=https://stocks-platform-seven.vercel.app

# سر مسار الملخص اليومي (نفس CRON_SECRET المضبوط في Vercel)
CRON_SECRET=

# وقت الإرسال اليومي بتوقيت جهازك (ساعة:دقيقة — 24 ساعة)
SEND_TIME=22:30

# أيام الإرسال: 1=الاثنين .. 5=الجمعة (أيام عمل السوق الأمريكي)
SEND_DAYS=1,2,3,4,5

# اتركه self للإرسال إلى نفسك (محادثة «أنا»)، أو ضع رقماً دولياً بلا + مثل 9665xxxxxxxx
SEND_TO=self

# منفذ صفحة الحالة المحلية
PORT=8899

# فاصل سحب التنبيهات اللحظية من /api/alerts بالدقائق (الحد الأدنى 2)
ALERT_POLL_MIN=5
